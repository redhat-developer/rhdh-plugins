{
  "extends": "@backstage/cli/config/tsconfig.json",
  "include": [
    "packages/*/src",
    "packages/*/config.d.ts",
    "plugins/*/src",
    "plugins/*/config.d.ts",
    "plugins/*/dev",
    "plugins/*/migrations"
  ],
  "exclude": ["node_modules", "**/node_modules"],
  "compilerOptions": {
    "outDir": "dist-types",
    "rootDir": ".",
    "jsx": "react-jsx",
    "paths": {
      "@kagenti/adk/core": ["./node_modules/@kagenti/adk/dist/core.d.ts"],
      "@kagenti/adk/extensions": [
        "./node_modules/@kagenti/adk/dist/extensions.d.ts"
      ]
    }
  }
}

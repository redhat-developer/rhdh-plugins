{
  "name": "@red-hat-developer-hub/backstage-plugin-intelligent-assistant",
  "version": "3.0.3",
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.tsx",
    "./alpha": "./src/alpha.ts",
    "./legacy": "./src/legacy.ts",
    "./intelligent-assistant-fab-module": "./src/lightspeedFABModuleExport.ts",
    "./intelligent-assistant-translations-module": "./src/lightspeedTranslationsModuleExport.ts",
    "./dev": "./dev/CustomDrawer.tsx",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "alpha": [
        "src/alpha.ts"
      ],
      "legacy": [
        "src/legacy.ts"
      ],
      "intelligent-assistant-fab-module": [
        "src/lightspeedFABModuleExport.ts"
      ],
      "intelligent-assistant-translations-module": [
        "src/lightspeedTranslationsModuleExport.ts"
      ],
      "dev": [
        "dev/CustomDrawer.tsx"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "intelligent-assistant",
    "pluginPackage": "@red-hat-developer-hub/backstage-plugin-intelligent-assistant",
    "pluginPackages": [
      "@red-hat-developer-hub/backstage-plugin-intelligent-assistant",
      "@red-hat-developer-hub/backstage-plugin-intelligent-assistant-backend",
      "@red-hat-developer-hub/backstage-plugin-intelligent-assistant-common"
    ]
  },
  "sideEffects": [
    "./**/*.css"
  ],
  "scripts": {
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "lint:check": "backstage-cli package lint",
    "lint:fix": "backstage-cli package lint --fix",
    "postpack": "backstage-cli package postpack",
    "prepack": "backstage-cli package prepack",
    "start": "backstage-cli package start",
    "test": "backstage-cli package test --passWithNoTests --coverage",
    "tsc": "tsc",
    "prettier:check": "prettier --ignore-unknown --check .",
    "prettier:fix": "prettier --ignore-unknown --write ."
  },
  "dependencies": {
    "@backstage/core-components": "^0.18.11",
    "@backstage/core-plugin-api": "^1.12.7",
    "@backstage/frontend-plugin-api": "^0.17.2",
    "@backstage/plugin-app-react": "^0.2.4",
    "@backstage/plugin-permission-react": "^0.5.2",
    "@backstage/theme": "^0.7.3",
    "@material-ui/core": "^4.9.13",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^6.1.8",
    "@mui/material": "^5.12.2",
    "@mui/styles": "5.18.0",
    "@patternfly/chatbot": "6.6.0",
    "@patternfly/react-core": "6.6.0",
    "@patternfly/react-icons": "^6.5.0",
    "@patternfly/react-table": "^6.4.1",
    "@red-hat-developer-hub/backstage-plugin-app-react": "^0.1.0",
    "@red-hat-developer-hub/backstage-plugin-intelligent-assistant-common": "workspace:^",
    "@red-hat-developer-hub/backstage-plugin-theme": "^0.14.10",
    "@tanstack/react-query": "^5.59.15",
    "monaco-editor": "^0.55.0",
    "react-dropzone": "^14.4.0",
    "react-use": "^17.2.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/core-app-api": "^1.20.2",
    "@backstage/dev-utils": "^1.1.24",
    "@backstage/test-utils": "^1.7.19",
    "@emotion/is-prop-valid": "^1.3.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@spotify/prettier-config": "^15.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "14.6.1",
    "prettier": "3.9.5",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0"
  },
  "files": [
    "dist",
    "config.d.ts",
    "dist-scalprum",
    "app-config.yaml"
  ],
  "scalprum": {
    "name": "red-hat-developer-hub.backstage-plugin-intelligent-assistant",
    "exposedModules": {
      "PluginRoot": "./src/index.tsx",
      "Alpha": "./src/alpha.ts",
      "Legacy": "./src/legacy.ts",
      "IntelligentAssistantFABModule": "./src/lightspeedFABModuleExport.ts",
      "IntelligentAssistantTranslationsModule": "./src/lightspeedTranslationsModuleExport.ts"
    }
  },
  "configSchema": "config.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redhat-developer/rhdh-plugins.git",
    "directory": "workspaces/intelligent-assistant/plugins/intelligent-assistant"
  },
  "keywords": [
    "backstage",
    "plugin"
  ],
  "homepage": "https://red.ht/rhdh",
  "bugs": "https://github.com/redhat-developer/rhdh-plugins/issues",
  "maintainers": [
    "@karthikjeeyar",
    "@rohitkrai03",
    "@debsmita1"
  ],
  "author": "Red Hat"
}

{
  "name": "@red-hat-developer-hub/backstage-plugin-theme",
  "version": "0.14.5",
  "description": "Red Hat Developer Hub Theme",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/redhat-developer/rhdh-plugins",
    "directory": "workspaces/theme/plugins/theme"
  },
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "rhdh-theme",
    "pluginPackages": [
      "@red-hat-developer-hub/backstage-plugin-theme"
    ]
  },
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha/index.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "alpha": [
        "src/alpha/index.ts"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "scripts": {
    "start": "backstage-cli package start",
    "start:legacy": "backstage-cli package start --entrypoint dev/legacy.tsx",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "peerDependencies": {
    "@backstage/core-plugin-api": "^1.12.4",
    "@backstage/theme": "^0.7.2",
    "@material-ui/icons": "^4.11.3",
    "@mui/icons-material": "^5.17.1",
    "@mui/material": "^5.0.0",
    "react": "^16.13.1 || ^17.0.0 || ^18.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0",
    "@backstage/core-app-api": "^1.19.6",
    "@backstage/core-components": "^0.18.8",
    "@backstage/core-plugin-api": "^1.12.4",
    "@backstage/dev-utils": "^1.1.21",
    "@backstage/frontend-defaults": "^0.5.0",
    "@backstage/plugin-user-settings": "^0.9.1",
    "@backstage/test-utils": "^1.7.16",
    "@backstage/theme": "^0.7.2",
    "@backstage/types": "^1.2.2",
    "@backstage/ui": "^0.13.1",
    "@material-ui/icons": "^4.11.3",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "msw": "^1.0.0",
    "react": "^16.13.1 || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.13.1 || ^17.0.0 || ^18.0.0"
  },
  "configSchema": "config.d.ts",
  "files": [
    "app-config.dynamic.yaml",
    "config.d.ts",
    "dist"
  ],
  "author": "Red Hat",
  "homepage": "https://red.ht/rhdh",
  "keywords": [
    "backstage",
    "rhdh",
    "theme",
    "redhat"
  ],
  "maintainers": [
    "@christoph-jerolimov",
    "@ciiay",
    "@debsmita1",
    "@divyanshiGupta"
  ],
  "dependencies": {
    "@backstage/frontend-plugin-api": "^0.15.1",
    "@backstage/plugin-app-react": "^0.2.1",
    "@mui/icons-material": "^5.17.1"
  }
}

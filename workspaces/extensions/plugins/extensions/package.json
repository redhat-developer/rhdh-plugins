{
  "name": "@red-hat-developer-hub/backstage-plugin-extensions",
  "version": "0.18.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/redhat-developer/rhdh-plugins",
    "directory": "workspaces/extensions/plugins/extensions"
  },
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "extensions",
    "pluginPackages": [
      "@red-hat-developer-hub/backstage-plugin-extensions",
      "@red-hat-developer-hub/backstage-plugin-extensions-backend",
      "@red-hat-developer-hub/backstage-plugin-extensions-common"
    ]
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha/index.tsx",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "alpha": [
        "src/alpha/index.tsx"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "scripts": {
    "start": "backstage-cli package start",
    "start:legacy": "backstage-cli package start --entrypoint dev/legacy.tsx",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/catalog-client": "^1.16.0",
    "@backstage/core-compat-api": "^0.5.12",
    "@backstage/core-components": "^0.18.11",
    "@backstage/core-plugin-api": "^1.12.7",
    "@backstage/frontend-defaults": "^0.5.3",
    "@backstage/frontend-plugin-api": "^0.17.2",
    "@backstage/plugin-app-react": "^0.2.4",
    "@backstage/plugin-catalog-react": "^3.1.0",
    "@backstage/theme": "^0.7.3",
    "@backstage/types": "^1.2.2",
    "@backstage/ui": "^0.16.0",
    "@material-table/core": "^6.4.4",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "5.18.0",
    "@mui/material": "5.18.0",
    "@mui/styles": "5.18.0",
    "@red-hat-developer-hub/backstage-plugin-extensions-common": "workspace:^",
    "@tanstack/react-query": "^5.60.5",
    "monaco-editor": "^0.55.0",
    "yaml": "^2.7.0"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-router-dom": "^6.3.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/dev-utils": "^1.1.24",
    "@backstage/test-utils": "^1.7.19",
    "@red-hat-developer-hub/backstage-plugin-theme": "^0.14.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-router-dom": "^6.3.0"
  },
  "files": [
    "app-config.dynamic.yaml",
    "dist"
  ]
}

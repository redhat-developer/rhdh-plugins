{
  "name": "@internal/ai-integrations",
  "version": "1.0.0",
  "engines": {
    "node": "22 || 24"
  },
  "scripts": {
    "dev": "yarn workspaces foreach -A --include backend --include app --parallel -v -i run start",
    "dev:debug": "yarn workspaces foreach -A --include backend --include app --parallel -v -i run start --inspect",
    "start": "yarn workspace app start",
    "start-backend": "yarn workspace backend start",
    "build:backend": "yarn workspace backend build",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck true --incremental false",
    "build:all": "backstage-cli repo build --all",
    "build:api-reports": "yarn build:api-reports:only --tsc",
    "build:api-reports:only": "backstage-repo-tools api-reports -o ae-wrong-input-file-type,ae-undocumented --validate-release-tags",
    "build:knip-reports": "backstage-repo-tools knip-reports",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --coverage",
    "fix": "backstage-cli repo fix",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "new": "backstage-cli new --scope @red-hat-developer-hub",
    "postinstall": "cd ../../ && yarn install"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/redhat-developer/rhdh-plugins",
    "directory": "workspaces/ai-integrations"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/cli-defaults": "^0.1.3",
    "@backstage/e2e-test-utils": "^0.1.2",
    "@backstage/repo-tools": "^0.17.3",
    "@changesets/cli": "^2.27.1",
    "knip": "^5.27.4",
    "node-gyp": "^9.0.0",
    "prettier": "^2.3.2",
    "typescript": "~5.7.0"
  },
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "isolated-vm": "^6.0.1",
    "@backstage/plugin-catalog": "2.0.1",
    "@backstage/plugin-catalog-react": "^2.1.1"
  },
  "prettier": "@backstage/cli/config/prettier",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}

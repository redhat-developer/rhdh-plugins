{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch RHDH AI (dev cluster)",
            "runtimeExecutable": "/usr/local/bin/yarn",
            "cwd": "${workspaceFolder}",
            "runtimeArgs": ["dev:debug"],
            "env": {
                "KUBECONFIG": "${env:HOME}/.kube/config",
                "RHDH_TOKEN": "local-dev-token",
                "RHDH_BRIDGE_HOST": "localhost",
                "OWNER": "rkichann",
                "LIFECYCLE": "development"
            }
        }
    ]
}

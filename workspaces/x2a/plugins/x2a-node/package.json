{
  "name": "@red-hat-developer-hub/backstage-plugin-x2a-node",
  "version": "0.3.0",
  "license": "Apache-2.0",
  "description": "Shared backend API surface (interfaces, service refs, utilities) for x2a plugins",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/redhat-developer/rhdh-plugins",
    "directory": "workspaces/x2a/plugins/x2a-node"
  },
  "backstage": {
    "role": "node-library",
    "pluginId": "x2a",
    "pluginPackages": [
      "@red-hat-developer-hub/backstage-plugin-x2a",
      "@red-hat-developer-hub/backstage-plugin-x2a-backend",
      "@red-hat-developer-hub/backstage-plugin-x2a-common",
      "@red-hat-developer-hub/backstage-plugin-x2a-node"
    ]
  },
  "sideEffects": false,
  "scripts": {
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "^1.4.2",
    "@backstage/catalog-model": "^1.7.5",
    "@backstage/plugin-catalog-node": "^1.20.0",
    "@backstage/plugin-permission-common": "^0.9.3",
    "@red-hat-developer-hub/backstage-plugin-x2a-common": "workspace:*"
  },
  "devDependencies": {
    "@backstage/cli": "^0.34.5"
  },
  "files": [
    "dist"
  ],
  "maintainers": [
    "@mareklibra",
    "@elai-shalev",
    "@eloycoto"
  ]
}

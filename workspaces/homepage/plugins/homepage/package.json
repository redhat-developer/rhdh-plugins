{
  "name": "@red-hat-developer-hub/backstage-plugin-homepage",
  "version": "1.15.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/redhat-developer/rhdh-plugins",
    "directory": "workspaces/homepage/plugins/homepage"
  },
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "homepage",
    "pluginPackages": [
      "@red-hat-developer-hub/backstage-plugin-homepage",
      "@red-hat-developer-hub/backstage-plugin-homepage-backend",
      "@red-hat-developer-hub/backstage-plugin-homepage-common"
    ]
  },
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha/index.ts",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "alpha": [
        "src/alpha/index.ts"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "scripts": {
    "start": "backstage-cli package start",
    "start:legacy": "backstage-cli package start --entrypoint dev/legacy.tsx",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/catalog-client": "^1.16.0",
    "@backstage/catalog-model": "^1.9.0",
    "@backstage/core-compat-api": "^0.5.12",
    "@backstage/core-components": "^0.18.11",
    "@backstage/core-plugin-api": "^1.12.7",
    "@backstage/frontend-plugin-api": "^0.17.2",
    "@backstage/plugin-app-react": "^0.2.4",
    "@backstage/plugin-catalog-react": "^3.1.0",
    "@backstage/plugin-home": "^0.9.7",
    "@backstage/plugin-home-react": "^0.1.39",
    "@backstage/plugin-search-react": "^1.11.5",
    "@backstage/plugin-user-settings": "^0.9.4",
    "@backstage/theme": "^0.7.3",
    "@mui/icons-material": "5.18.0",
    "@mui/material": "5.18.0",
    "@mui/styles": "5.18.0",
    "@red-hat-developer-hub/backstage-plugin-homepage-common": "workspace:^",
    "@scalprum/react-core": "0.11.3",
    "react-grid-layout": "1.5.3",
    "react-use": "17.6.1"
  },
  "peerDependencies": {
    "react": "16.13.1 || ^17.0.0 || ^18.2.0",
    "react-dom": "*",
    "react-router-dom": "6.30.4"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/core-app-api": "^1.20.2",
    "@backstage/dev-utils": "^1.1.24",
    "@backstage/frontend-defaults": "^0.5.3",
    "@backstage/plugin-catalog": "^2.0.6",
    "@backstage/plugin-search": "^1.7.5",
    "@backstage/test-utils": "^1.7.19",
    "@backstage/ui": "^0.16.0",
    "@openshift/dynamic-plugin-sdk": "5.0.1",
    "@red-hat-developer-hub/backstage-plugin-theme": "^0.14.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "14.3.1",
    "@testing-library/user-event": "14.6.1",
    "@types/react-grid-layout": "1.3.6",
    "msw": "1.3.5",
    "react": "^16.13.1 || ^17.0.0 || ^18.0.0"
  },
  "files": [
    "app-config.dynamic.yaml",
    "dist"
  ]
}
